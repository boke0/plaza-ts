{
  "name": "plaza-example-do",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,wrangler -c blue,magenta \"vite build --watch\" \"wrangler dev\"",
    "build:client": "vite build",
    "deploy": "vite build && wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.client.json"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "plaza-ts": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251201.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.9.0",
    "vite": "^5.4.0",
    "wrangler": "^4.50.0"
  }
}
